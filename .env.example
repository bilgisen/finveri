APP_NAME=Financial Data API
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Redis
REDIS_URL=rediss://default:PASSWORD@host:port

# Worker
FETCH_INTERVAL_SECONDS=300
CACHE_TTL_SECONDS=600
HTTP_TIMEOUT_SECONDS=15
ONDEMAND_CACHE_TTL_SECONDS=60

# Kaynak URL'leri
OYAK_INSTRUMENTS_URL=https://www.oyakyatirim.com.tr/Home/GetAllInstruments
AA_BIST_URL=https://aafinans.com/Veri/SektorEndeksineAitTradeStatistics3leriVerDetay?sektorId=1
AA_MARKET_SUMMARY_URL=https://aafinans.com/Navigation/UstBarSembolListesiniAl
ISYATIRIM_QUOTE_URL=https://www.isyatirim.com.tr/_layouts/15/Isyatirim.Website/Common/Data.aspx/OneEndeks

# Database configuration
DATABASE_URL="sqlite+aiosqlite:///./finveri.db"
OVH_DATABASE_URL="postgresql+asyncpg://user:pass@host:port/dbname"
OVH_SSL_CERT="ovh_ca.pem"

# Gemini API Key
GEMINI_API_KEY=""

# Celery Configuration (Optional)
CELERY_BROKER_URL=""
CELERY_RESULT_BACKEND=""
